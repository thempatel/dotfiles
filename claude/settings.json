{
  "cleanupPeriodDays": 365,
  "showThinkingSummaries": true,
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "autoUpdates": true,
  "effortLevel": "high",
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-window-finder notify --on --agent claude"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-window-finder notify --on --agent claude"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-window-finder notify --off --agent claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-window-finder notify --off --agent claude"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "tmux-window-finder notify --off --agent claude"
          }
        ]
      }
    ]
  }
}
