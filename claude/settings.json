{
  "cleanupPeriodDays": 365,
  "showThinkingSummaries": true,
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "autoUpdates": true,
  "model": "claude-opus-4-6",
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "MAX_THINKING_TOKENS": "128000"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-window-finder notify --on --agent claude"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-window-finder notify --on --agent claude"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-window-finder notify --off --agent claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-window-finder notify --off --agent claude"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "tmux-window-finder notify --off --agent claude"
          }
        ]
      }
    ]
  }
}
