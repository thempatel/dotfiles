{
  "includeCoAuthoredBy": false,
  "cleanupPeriodDays": 365,
  "showThinkingSummaries": true,
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "autoUpdates": true,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-window-finder notify --on --agent claude"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-window-finder notify --on --agent claude"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-window-finder notify --working --agent claude"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tmux-window-finder notify --working --agent claude"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "tmux-window-finder notify --off --agent claude"
          }
        ]
      }
    ]
  }
}
