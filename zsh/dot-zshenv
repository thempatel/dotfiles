# Snapshot env before dotfiles touch anything, used by reload!
typeset -aU _reload_env_before=( ${(k)parameters[(R)*export*]} )
_reload_path_before="$PATH"

typeset -U PATH path

export SHELL_SESSIONS_DISABLE=1

SCRIPT_PATH="${(%):-%x}"
export DOTFILES_HOME="${SCRIPT_PATH:A:h:h}"
export MISE_GLOBAL_CONFIG_FILE="$DOTFILES_HOME/mise.toml"
export MISE_TRUSTED_CONFIG_PATHS="$MISE_GLOBAL_CONFIG_FILE"

path+=("$DOTFILES_HOME/bin" "$HOME/.local/bin")
